# ------------------------------------------
# GENERAL
# ------------------------------------------

DOMAIN=mydomain.com
TZ=Europe/Madrid

# Docker Compose project name. 
# Used as a prefix for all containers (e.g., PROJECT_NAME-traefik-1)
PROJECT_NAME=stack

# ------------------------------------------
# ANUBIS
# ------------------------------------------

ANUBIS_DIFFICULTY=4

# redis key (openssl rand -hex 32)
ANUBIS_REDIS_PRIVATE_KEY=REPLACE_ME

# Resources for each instance: fine-tuning to avoid choking the server or allowing more traffic
ANUBIS_CPU_LIMIT=0.10
ANUBIS_MEM_LIMIT=32M

# Resources for the small aux container with custom static resources for personalizing anubis
ANUBIS_ASSETS_CPU_LIMIT=0.10
ANUBIS_ASSETS_MEM_LIMIT=64M

# ------------------------------------------
# REDIS
# ------------------------------------------

REDIS_PASSWORD=REPLACE_ME

# ------------------------------------------
# CROWDSEC
# ------------------------------------------

# Set to false to completely disable the CrowdSec firewall.
CROWDSEC_ENABLE=true

# To generate a new key:
# If an old one exists, first: docker exec -t crowdsec cscli bouncers delete traefik-bouncer
# And then: docker exec -t crowdsec cscli bouncers add traefik-bouncer
CROWDSEC_API_KEY=REPLACE_ME

# How often (seconds) the plugin downloads the blacklist from the LAPI.
# Lowering it increases CPU/Network load, raising it increases risk of fresh IPs.
# 15s is a good balance for production with active attack traffic.
CROWDSEC_UPDATE_INTERVAL=15

# (Optional) Enrollment key for CrowdSec Console.
# Get your key from https://app.crowdsec.net after creating an account.
# Leave empty to skip console enrollment.
CROWDSEC_ENROLLMENT_KEY=

# Enable CrowdSec AppSec (WAF) component.
# Requires the appsec collections to be installed (added automatically when enabled).
# Set to false to disable Layer 7 inspection (the acquis.yaml AppSec block will be omitted).
CROWDSEC_APPSEC_ENABLE=true

# CrowdSec Collections (scenarios/parsers to load)
# Remove 'crowdsecurity/http-dos' if you get too many false positives
# NOTE: AppSec collections (appsec-virtual-patching, appsec-generic-rules) are appended
# automatically by start.sh when CROWDSEC_APPSEC_ENABLE=true. Do not add them manually.
CROWDSEC_COLLECTIONS='crowdsecurity/traefik crowdsecurity/http-cve crowdsecurity/sshd crowdsecurity/whitelist-good-actors crowdsecurity/base-http-scenarios crowdsecurity/http-dos'

# (Optional) Comma-separated list of IP addresses/CIDR ranges to whitelist.
# These IPs bypass CrowdSec detection AND AppSec inspection entirely.
# Example: 203.0.113.50,198.51.100.0/24
CROWDSEC_WHITELIST_IPS=

# --- CrowdSec Web UI (internal service credentials) ---
# Automated login for the web interface to talk to the local API.
CROWDSEC_WEB_UI_USER=crowdsec-web-ui
CROWDSEC_WEB_UI_PASSWORD=REPLACE_ME

# IPs allowed to perform delete operations in the CrowdSec Web UI.
# Since this UI is already protected by SSO (ForwardAuth), the web UI's IP check
# is redundant — authentication is handled by Traefik before the request ever
# reaches the UI. Setting 0.0.0.0/0 allows any authenticated user to delete.
# If you expose the UI without SSO, restrict this to your admin IP.
CROWDSEC_WEB_UI_TRUSTED_IPS=0.0.0.0/0


# ------------------------------------------
# TRAEFIK
# ------------------------------------------

# Local IP address to listen on for ports 80/443.
# Default: 0.0.0.0 (all interfaces)
TRAEFIK_LISTEN_IP=0.0.0.0

# Default average requests per second
TRAEFIK_GLOBAL_RATE_AVG=60

# Default allowed burst (peak)
TRAEFIK_GLOBAL_RATE_BURST=120

# Default concurrent requests (in-flight)
TRAEFIK_GLOBAL_CONCURRENCY=25

# Traefik Timeouts (in seconds)
# Active: readTimeout, writeTimeout, responseHeaderTimeout
TRAEFIK_TIMEOUT_ACTIVE=60

# Idle: idleTimeout, idleConnTimeout
TRAEFIK_TIMEOUT_IDLE=90

# IP address of the host machine as seen from Docker containers.
# Default: 172.17.0.1 (docker0 bridge on Linux)
# Use 'host.docker.internal' on Docker Desktop (macOS/Windows)
APACHE_HOST_IP=172.17.0.1

# Port where the host Apache listens. Used to auto-detect Apache and configure the proxy target.
APACHE_HOST_PORT=8080

# (Optional) Comma-separated list of path prefixes to block globally across all domains (regex supported).
# Example: "/root/,/wp-admin/,/xmlrpc.php"
TRAEFIK_BLOCKED_PATHS=""

# (Optional) Comma-separated list of User-Agent regex patterns to blacklist globally.
# These patterns are blocked natively and instantly by Traefik.
# Patterns use Go Regexp syntax and are matched against the entire User-Agent string.
# Example: "(?i).*curl.*,(?i).*BadBot.*,(?i).*Go-http-client.*"
TRAEFIK_BAD_USER_AGENTS=

# (Optional) Comma-separated list of User-Agent regex patterns to whitelist globally.
# Good User Agents (Comma-separated list of regex patterns)
# Patterns use Go Regexp syntax and are matched against the entire User-Agent string.
# Example: "(?i).*Zend_Http_Client.*"
TRAEFIK_GOOD_USER_AGENTS=""

# Access Log buffering size. 
# 1000: Good for production (batch writes). 
# 0 or 1: Good for testing (immediate log visibility).
TRAEFIK_ACCESS_LOG_BUFFER=1000

# Traefik Log Level (DEBUG, INFO, WARN, ERROR, FATAL, PANIC)
# DEBUG: detailed ACME logs
# INFO: standard operations (default)
TRAEFIK_LOG_LEVEL=INFO

# Security Headers middleware: HSTS Max Age in seconds.
# CAUTION: Use 0 to disable or low values (300) during testing.
# Use 31536000 (1 year) only when everything is stable.
TRAEFIK_HSTS_MAX_AGE=31536000

# (Optional) Comma-separated list of external domains allowed to embed this site in an iframe.
# Example: https://external-site.com,https://another-site.org
# If left empty, iframes are blocked by default (SAMEORIGIN).
TRAEFIK_FRAME_ANCESTORS=""

# Required for Let's Encrypt certificate issuance
TRAEFIK_ACME_EMAIL=email@mydomain.com

# ACME Environment Type: 'staging', 'production' or 'local'
# staging:    https://acme-staging-v02.api.letsencrypt.org/directory (Safe for testing)
# production: https://acme-v02.api.letsencrypt.org/directory (Real certs, strict limits)
# local:      Self-signed certificates (No Let's Encrypt). Use for local dev with .local domains.
TRAEFIK_ACME_ENV_TYPE=staging

# TLS cert resolver name. Auto-managed by start.sh based on TRAEFIK_ACME_ENV_TYPE.
# 'le' for staging/production, empty for local. DO NOT EDIT MANUALLY!!!
TRAEFIK_CERT_RESOLVER=

# (Optional) Direct URL override.
# Note: TRAEFIK_ACME_ENV_TYPE takes precedence if set. 
# To use this custom URL, leave TRAEFIK_ACME_ENV_TYPE empty or commented out.
# TRAEFIK_ACME_CA_SERVER=

# ------------------------------------------
# WATCHDOG
# ------------------------------------------

# Telegram bot token and recipient ID
WATCHDOG_TELEGRAM_BOT_TOKEN=REPLACE_ME
WATCHDOG_TELEGRAM_RECIPIENT_ID=REPLACE_ME

# Certificate expiration warning threshold (days)
WATCHDOG_CERT_DAYS_WARNING=10

# DNS check interval in seconds (default: 6 hours = 21600)
WATCHDOG_DNS_CHECK_INTERVAL=21600

# How often (seconds) the watchdog checks CrowdSec health.
WATCHDOG_CROWDSEC_CHECK_INTERVAL=3600

# How often (seconds) the watchdog checks system/stack health (containers, disk, Redis).
WATCHDOG_SYSTEM_CHECK_INTERVAL=300

# How often (seconds) the watchdog checks Traefik configuration (routers, services, middlewares).
WATCHDOG_TRAEFIK_CHECK_INTERVAL=300


# ------------------------------------------
# GRAFANA
# ------------------------------------------

# Grafana Admin Credentials (for full admin access inside Grafana)
# By default, anonymous users (via SSO) get Viewer access.
# Use these credentials to log in as Admin for configuration tasks.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=password

# ------------------------------------------
# DASHBOARD (SSO PROVIDER)
# ------------------------------------------

# DASHBOARD_APP_PATH_HOST is auto-calculated by start.sh
DASHBOARD_APP_PATH_HOST=REPLACE_ME
DASHBOARD_SECRET_KEY=REPLACE_ME

# Subdomain for the dashboard (e.g. 'dashboard' -> dashboard.mydomain.com)
DASHBOARD_SUBDOMAIN=dashboard

# Dashboard login credentials
DASHBOARD_ADMIN_USER=admin
DASHBOARD_ADMIN_PASSWORD=password