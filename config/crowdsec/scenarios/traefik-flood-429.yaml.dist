# =============================================================================
# custom/traefik-flood-429
# =============================================================================
# Detects IPs that repeatedly trigger Traefik's rate limiter (429 responses).
# This fills the gap where AppSec/LAPI don't act on rate-limited traffic.
# An IP generating 50+ rate-limited requests in a tight window is blocked.
# =============================================================================

type: leaky
name: custom/traefik-flood-429
description: "IP flooding Traefik and repeatedly hitting rate limits (429)"
filter: "evt.Meta.log_type == 'http_access-log' && evt.Meta.http_status == '429'"
groupby: evt.Meta.source_ip
capacity: 50
leakspeed: "1s"
blackhole: 15m
labels:
  service: traefik
  type: dos
  remediation: true
